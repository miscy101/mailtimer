<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <!-- Identity -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>0.1.0</Version>
  <ProviderName>Mailtimer</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Mailtimer" />
  <Description DefaultValue="A countdown timer that sends your email when it reaches zero." />
  <IconUrl DefaultValue="https://miscy101.github.io/mailtimer/icons/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://miscy101.github.io/mailtimer/icons/icon-64.png" />
  <SupportUrl DefaultValue="https://miscy101.github.io/mailtimer" />

  <AppDomains>
    <AppDomain>https://miscy101.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="Mailbox" />
    </Sets>
  </Requirements>

  <!-- FormSettings required by schema even though VersionOverrides takes over -->
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://miscy101.github.io/mailtimer/outlook/taskpane/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <!-- Rule required by schema, ignored when VersionOverrides is present -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="Mailtimer.Group">
                <!-- In mail add-ins, Group only allows Label, Tooltip, Control.
                     No Icon at the Group level  -  icons go inside each Control. -->
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="Mailtimer.TaskpaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://miscy101.github.io/mailtimer/icons/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://miscy101.github.io/mailtimer/icons/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://miscy101.github.io/mailtimer/icons/icon-64.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://miscy101.github.io/mailtimer/outlook/commands.html" />
        <bt:Url id="Taskpane.Url"  DefaultValue="https://miscy101.github.io/mailtimer/outlook/taskpane/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"           DefaultValue="Mailtimer" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Mailtimer" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Mailtimer countdown panel." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
